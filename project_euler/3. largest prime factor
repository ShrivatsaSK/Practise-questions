#include <iostream>
using namespace std;

int main() {
    long long n;
    cout << "Enter the number: ";
    cin >> n;

    long long largestPrimeFactor = 0;
    for(long long i = 2; i * i <= n; i++) {
        while(n % i == 0) {
            largestPrimeFactor = i;
            n /= i;
        }
    }
    if(n > 1) {
        largestPrimeFactor = n;
    }
    cout << largestPrimeFactor << " is the largest prime factor.\n";
    return 0;
}
