#include <iostream>
using namespace std;

bool ispalindrome(int n){
    int original = n;
    int reverse = 0;
    while(n>0){
        reverse = (reverse * 10) + (n%10);
        n /= 10;
    }
    return original == reverse;
}

int main() {
    int largest, num1, num2, product, i, j;
    for(i=999;i>100;i--){
        for(j=999;j>100;j--){
            product = i*j;
            
            if(ispalindrome(product)&& product>largest){
                largest = product;
                num1 = i;
                num2 = j;
            }
        }
    }
    cout <<"The largest palindrome is : "<<largest<< "\n";
    cout << "Produced by: " << num1 << " x " << num2 << "\n";
    return 0;
}
