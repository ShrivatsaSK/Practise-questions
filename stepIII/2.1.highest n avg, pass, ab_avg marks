#include <iostream>
using namespace std;
int main(){
    int n, sum=0, max=0, pass=0, i, count=0;
    cout <<"Enter the number of items : ";
    cin >>n;
    int arr[n];
    cout <<"Enter the items :";
    for (i=0; i<n; i++){
        cin>>arr[i];
        sum= sum+arr[i];
        if (arr[i]>max){
            max = arr[i];
        }
        if (arr[i]>= 40){
           pass++; 
        }
    }
    float avg= (float) sum/n;
    for(i=0;i<n; i++){
        if (arr[i]>avg){
            count++;
        }
    }
    cout <<"Average : "<<avg<<endl;
    cout <<"Highest : "<<max<<endl;
    cout <<"Passed : "<<pass<<endl;
    cout <<"Above average : "<<count;

    return 0;
}
