#include <iostream>
using namespace std;

int main() {
    cout<<"Enter the elements of 3x3 matrix : \n";
    int arr1[3][3];
    for(int i=0; i<3; i++){
        for(int j=0; j<3; j++){
            cin>>arr1[i][j];
        }
    }
    cout<<"Rotated matrix : \n";
    for(int j=0; j<3; j++){
        for(int i=2; i>=0; i--){
            cout<<arr1[i][j]<<" ";
        }
        cout<<endl;
    }
    return 0;
}
