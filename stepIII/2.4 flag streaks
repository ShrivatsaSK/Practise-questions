#include <iostream>
using namespace std;

int act(int n, int arr[]) {
    int count = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] == 1) {
            count++;
        }
    }
    return count;
}

int streak(int n, int arr[]) {
    int longest = 0;
    int current = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] == 1) {
            current++;
            if (current > longest) {
                longest = current;
            }
        } else {
            current = 0;
        }
    }
    return longest;
}

int cur_streak(int n, int arr[]) {
    int current = 0;
    for (int i = n - 1; i >= 0; i--) {
        if (arr[i] == 1) {
            current++;
        } else {
            break;
        }
    }
    return current;
}

int main() {
    int n;
    cout << "Enter the number of days: ";
    cin >> n;
    int arr[n];
    cout << "Enter flags (0/1) with space: ";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }
    cout << "Active Days: " << act(n, arr) << endl;
    cout << "Longest Streak: " << streak(n, arr) << endl;
    cout << "Current Streak: " << cur_streak(n, arr) << endl;
    return 0;
}
