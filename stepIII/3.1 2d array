#include <iostream>
using namespace std;

void result(int r, int c, int arr1[][10], int arr2[][10]) {
    int arr3[10][10];

    cout << "The result matrix is:\n";

    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            arr3[i][j] = arr1[i][j] + arr2[i][j];
            cout << arr3[i][j] << " ";
        }
        cout << endl;
    }
}

int main() {
    int r, c;

    cout << "Enter value of row and column: ";
    cin >> r >> c;

    int arr1[10][10], arr2[10][10];

    cout << "Enter values for elements of matrix A:\n";
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            cin >> arr1[i][j];
        }
    }

    cout << "Enter values for elements of matrix B:\n";
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            cin >> arr2[i][j];
        }
    }

    result(r, c, arr1, arr2);

    return 0;
}
