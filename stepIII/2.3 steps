#include <iostream>
using namespace std;

double avg(int n, int arr[]) {
    int sum = 0;

    for (int i = 0; i < n; i++) {
        sum += arr[i];
    }

    return (double)sum / n;
}

int best_day(int n, int arr[]) {
    int max = arr[0];
    int day = 0;

    for (int i = 1; i < n; i++) {
        if (arr[i] > max) {
            max = arr[i];
            day = i;
        }
    }

    return day + 1; // 1-based day number
}

void good_day(int n, int arr[]) {
    for (int i = 0; i < n; i++) {
        if (arr[i] > 9999) {
            cout << "Day " << i + 1 << " (" << arr[i] << " steps)" << endl;
        }
    }
}

int main() {
    int n;

    cout << "Enter the number of days: ";
    cin >> n;

    int arr[n];

    cout << "Enter the step count of each day: ";

    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    cout << "Average Step Count: " << avg(n, arr) << endl;
    cout << "Best Day: " << best_day(n, arr) << endl;

    cout << "Good Days:" << endl;
    good_day(n, arr);

    return 0;
}
